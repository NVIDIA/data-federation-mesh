def yield_callback(_from_site: str, _node: int | str | None, _frame: Frame, _target_place: str, data):
    """Callback for yield operations."""
    if not data.status_code in [200, 204]:
        print(data.content)
    else:
        print("Success!")


def default_callback(_from_site: str, _node: int | str | None, _frame: Frame, _target_place: str, data):
    """Default callback for pipeline execution."""
    print(f"Default callback: {data}")


