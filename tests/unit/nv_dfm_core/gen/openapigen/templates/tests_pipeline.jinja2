def test_{{ import.alias }}(
{%- for param in import.parameters %}
    {{ param.name }}: {{ param.type }}{{ ", " if not loop.last else "" }}
{%- endfor %}
{%- if import.parameters %}, {% endif %}session_name: str = "local", timeout: int = 600):
    """
    Tests {{ import.alias }} operation with provided parameters.
    
    Parameters:
{%- for param in import.parameters %}
    - {{ param.name }} ({{ param.type }}){% if param.enum %}: One of {{ param.enum }}{% endif %}
{%- endfor %}
    - session_name (str): Session name to use (default: "local")
    - timeout (int): Timeout in seconds (default: 600)
    
    Returns:
        JobStatus: Status of the executed job
    """
    # Get and connect to session
    session = ogc_api_test.fed.runtime.ogc_site.get_session(session_name)
    session.connect()
    
    # Prepare pipeline
    pipeline = session.prepare(_create_pipeline_{{ import.alias }}())
    
    # Set up input parameters
    input_params = {
{%- for param in import.parameters %}
        "{{ param.name }}": {{ param.name }}{{ "," if not loop.last else "" }}
{%- endfor %}
    }
    
    # Execute pipeline
    job = session.execute(
        pipeline,
        input_params,
        place_callbacks={
            "yield": yield_callback,
            "api_response": yield_callback
        },
        default_callback=default_callback,
        debug=False
    )
    
    # Wait for completion
    job.wait_until_finished(timeout=timeout)
    status = job.get_status()
    print(f"Job status for {{ import.module}}.{{ import.name }}: {status}")
    
    # Close session
    session.close()
    
    return status
{%- endfor %}


