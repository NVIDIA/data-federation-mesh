set -e

PLATFORM="linux/{{ provision.docker.build.arch }}"
FILE="{{ provision.docker.dockerfile.dir }}/{{ provision.docker.dockerfile.file }}"
CONTEXT="{{ provision.docker.build.context | default('.') }}"
IMAGE="{{ provision.docker.image }}"
TAG="{{ provision.docker.tag }}"
DOCKER="{{ provision.docker.build.engine }}"
{%- if provision.docker.build.engine == "podman" %}
FORMAT="--format=docker" 
{%- endif %}

if [[ ! -f $FILE ]]; then
    echo "Dockerfile not found at $FILE"
    echo "Did you forget to change directory?"
    exit 1
fi

# Build image
$DOCKER build -t $IMAGE:$TAG  --platform $PLATFORM $FORMAT -f $FILE $CONTEXT

{%- if provision.docker.build.save.enabled %}

# Save image
IMAGE_FILE="{{provision.docker.build.save.file}}"
mkdir -p $(dirname $IMAGE_FILE)
$DOCKER save --output $IMAGE_FILE $IMAGE:$TAG

{%- endif %}

{%- if provision.docker.build.push.enabled %}

# Push image to repo
REPO="{{ provision.docker.build.push.registry.url }}"
USERNAME="{{ provision.docker.build.push.registry.username }}"
PASSWORD="{{ provision.docker.build.push.registry.password }}"

if [[ -n $USERNAME && -n $PASSWORD ]]; then
    echo $PASSWORD | $DOCKER login $REPO --username $USERNAME --password-stdin
fi

NAME=$REPO/$IMAGE:$TAG

$DOCKER tag $IMAGE:$TAG $NAME
$DOCKER push $NAME

{%- endif %}