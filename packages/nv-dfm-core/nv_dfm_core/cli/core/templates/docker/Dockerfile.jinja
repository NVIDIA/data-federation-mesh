# IMPORTANT
#
# This file is a template. Please add any project-specific operations to it.
# That includes installing any project-specific dependencies 
# (including DFM wheel package), copying federation-specific files and packages,
# etc.
#
###############################################################################

# Use NVIDIA Base Ubuntu 24.04 image
FROM nvcr.io/nvidia/base/ubuntu:noble-20250619

RUN DEBIAN_FRONTEND=noninteractive apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y \
    curl \
    vim \
    gcc \
    g++ \
    meson \
    libudunits2-dev \
    && rm -rf /var/lib/apt/lists/*

# Install uv from official image
COPY --from=ghcr.io/astral-sh/uv:0.8.13 /uv /uvx /bin/

# Install Python 3.12
RUN uv python install 3.12 --default -n

# Create app directory
RUN mkdir -p /app

# Tell eccodes to use system so library
ENV ECCODES_PYTHON_USE_FINDLIBS=1
ENV LD_LIBRARY_PATH=/lib/x86_64-linux-gnu/
# Set UDUNITS2 path for cf-units
ENV UDUNITS2_XML_PATH=/usr/share/xml/udunits/udunits2-common.xml

COPY ./{{ provision.docker.dockerfile.dir }}/run.sh /app

###############################################################################
# Add commands to install any project-specific dependencies and copy 
# federation-specific files and packages here.
# Example start here
###############################################################################

# Install DFM wheel as a dependency and copy federation-specific files
# Here we use a local wheel file, but federation projects can (and should) use
# their dependency management system to install the DFM wheel.
COPY ./{{ federation_dir_relative }}/deps/nv_dfm_core-*-py3-none-any.whl /app

WORKDIR /app
# Create a virtual environment and install the DFM wheel
RUN uv venv
RUN installed=false; \
    for i in {1..3}; do \
        if uv pip install nv_dfm_core-*-py3-none-any.whl; then \
            installed=true; \
            break; \
        fi; \
        echo "Installation attempt $i failed, retrying in 15s..."; \
        sleep 15; \
    done; \
    rm ./nv_dfm_core-*-py3-none-any.whl; \
    if [ "$installed" != "true" ]; then \
        echo "ERROR: Failed to install DFM wheel after 3 attempts"; \
        exit 1; \
    fi

# Copy additional federation files
RUN mkdir -p {{ name }}
COPY ./{{ federation_dir_relative }} ./{{ name }}/

###############################################################################
# Example ends here
###############################################################################

ENV NAME="{{ name }}"

# Mandatory ports
EXPOSE 8002
EXPOSE 8003

# Add uv Python to PATH for interactive sessions
ENV PATH="/root/.local/bin:$PATH"
# Set PATH to include uv's Python installations
RUN echo 'export PATH="/root/.local/bin:$PATH"' >> /root/.bashrc

CMD ["uv", "run", "./run.sh"]
