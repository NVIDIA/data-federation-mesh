{{- if .Values.[{ site_name }].enabled }}
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ printf "%s-[{ site_name }]" (include "data-federation-mesh.fullname" .) }}
  labels:
    {{- include "data-federation-mesh.labels" . | nindent 4 }}
    app.kubernetes.io/component: [{ site_name }]
spec:
  {{- if not .Values.autoscaling.enabled }}
  replicas: {{ .Values.[{ site_name }].replicaCount }}
  {{- end }}
  selector:
    matchLabels:
      {{- include "data-federation-mesh.selectorLabels" . | nindent 6 }}
      app.kubernetes.io/component: [{ site_name }]
  template:
    metadata:
      {{- with .Values.[{ site_name }].podAnnotations }}
      annotations:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      labels:
        {{- include "data-federation-mesh.labels" . | nindent 8 }}
        {{- with .Values.[{ site_name }].podLabels }}
        {{- toYaml . | nindent 8 }}
        {{- end }}
        app.kubernetes.io/component: [{ site_name }]
    spec:
      {{- with .Values.imagePullSecrets }}
      imagePullSecrets:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      {{- with .Values.[{ site_name }].podSecurityContext }}
      securityContext:
        {{- toYaml .Values.[{ site_name }].podSecurityContext | nindent 8 }}
      {{- end }}
      containers:
        - name: {{ .Chart.Name }}
          {{- with .Values.[{ site_name }].securityContext }}
          securityContext:
            {{- toYaml . | nindent 12 }}
          {{- end }}
          image: "{{ .Values.image.repository }}:{{ .Values.image.tag | default .Chart.AppVersion }}"
          imagePullPolicy: {{ .Values.image.pullPolicy }}
          ports:
            - name: http
              containerPort: {{ .Values.[{ site_name }].service.port }}
              protocol: TCP
          {{- with .Values.[{ site_name }].livenessProbe }}
          livenessProbe:
            {{- toYaml . | nindent 12 }}
          {{- end }}
          {{- with .Values.[{ site_name }].readinessProbe }}
          readinessProbe:
            {{- toYaml . | nindent 12 }}
          {{- end }}
          {{- with .Values.[{ site_name }].resources }}
          resources:
            {{- toYaml . | nindent 12 }}
          {{- end }}
          volumeMounts:
          {{- with .Values.[{ site_name }].volumeMounts }}
            {{- toYaml . | nindent 12 }}
          {{- end }}
            - name: workspace-init
              mountPath: {{ .Values.[{ site_name }].workspace.init.mount }}
              readOnly: true
          env:
          - name: DFM_FLARE_ROLE
            value: {{ .Values.[{ site_name }].role | quote }}
          - name: DFM_FLARE_SITE
            value: {{ .Values.[{ site_name }].site | quote }}
          - name: DFM_FLARE_WORKSPACE
            value: {{ .Values.[{ site_name }].workspace.path | quote }}
          - name: DFM_FLARE_WORKSPACE_INIT
            value: {{ .Values.[{ site_name }].workspace.init.path | quote }}
          - name: SERVICE_LOGGING_ENABLE_JSON
            value: {{ .Values.logging.json.enabled | quote }}
      automountServiceAccountToken: false
      volumes:
      {{- with .Values.[{ site_name }].volumes }}
        {{- toYaml . | nindent 8 }}
      {{- end }}
        - name: workspace-init
          secret:
            secretName: {{ .Values.[{ site_name }].workspace.init.secret | quote }}
      {{- with .Values.[{ site_name }].nodeSelector }}
      nodeSelector:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      {{- with .Values.[{ site_name }].affinity }}
      affinity:
        {{- toYaml . | nindent 8 }}
      {{- end }}
      {{- with .Values.[{ site_name }].tolerations }}
      tolerations:
        {{- toYaml . | nindent 8 }}
      {{- end }}
{{- end }}